# PricePin API — copy to .env (see MISTRAL_SETUP.md if you get 401 from Mistral)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# From https://console.mistral.ai/ — no quotes, no spaces
MISTRAL_API_KEY=your-mistral-api-key
# Optional: OCR model (default mistral-ocr-latest per cookbook). Override if your tier uses a different ID.
# MISTRAL_MODEL=mistral-ocr-latest
TURNSTILE_SECRET=your-cloudflare-turnstile-secret

# Admin: token for /admin/* routes (X-Admin-Token). Set in API only; never in frontend.
ADMIN_TOKEN=your-admin-token

# CORS: set one of these so the frontend origin is allowed. No trailing slashes.
# Option A: comma-separated list. Option B: single FRONTEND_URL (used when CORS_ORIGINS is unset).
# Default when both empty: http://localhost:5173, http://127.0.0.1:5173
# CORS_ORIGINS=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
