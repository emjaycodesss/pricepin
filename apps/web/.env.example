# PricePin frontend — copy to .env and fill (Vite exposes VITE_* only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:8000
# Mapbox (map tiles). Get a token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=

# Turnstile (public site key). Get it from the same Cloudflare Turnstile widget as TURNSTILE_SECRET (API). Required when API has TURNSTILE_SECRET set.
# VITE_TURNSTILE_SITE_KEY=your-site-key

# Admin: token is validated by the API (X-Admin-Token). Set ADMIN_TOKEN in apps/api/.env only; do not put it here.
