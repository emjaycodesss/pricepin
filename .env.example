# PricePin — root env example (documentation only; copy to .env and fill)
# Supabase (create project in Singapore region)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Backend (apps/api)
MISTRAL_API_KEY=your-mistral-api-key
TURNSTILE_SECRET=your-cloudflare-turnstile-secret
API_URL=http://localhost:8000

# Frontend uses VITE_* — see apps/web/.env.example
